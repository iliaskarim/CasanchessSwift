{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build",
      "type": "shell",
      "command": "swift build",
      "problemMatcher": [],
      "presentation": {
        "echo": false,
        "showReuseMessage": false,
        "clear": true
      }
    },
    {
      "label": "Build docs",
      "type": "shell",
      "command": "./scripts/build-docs",
      "problemMatcher": [],
      "presentation": {
        "echo": false,
        "clear": true
      }
    },
    {
      "label": "Build docs without base path",
      "type": "shell",
      "command": "./scripts/build-docs --no-base",
      "problemMatcher": [],
      "presentation": {
        "echo": false,
        "clear": true
      }
    },
    {
      "label": "Serve docs",
      "type": "shell",
      "command": "python3 -m http.server --directory ./docs",
      "problemMatcher": [],
      "presentation": {
        "echo": false,
        "showReuseMessage": false,
        "clear": true
      }
    },
    {
      "label": "Format all files",
      "type": "shell",
      "command": "/opt/homebrew/bin/swiftformat -v .",
      "problemMatcher": [],
      "presentation": {
        "echo": false,
        "showReuseMessage": false,
        "clear": true
      }
    },
    {
      "label": "Lint all files",
      "type": "shell",
      "command": "/opt/homebrew/bin/swiftlint .",
      "problemMatcher": [],
