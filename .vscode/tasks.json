        "echo": false,
        "showReuseMessage": false,
        "clear": true
      }
    },
    {
      "label": "Lint current file",
      "type": "shell",
      "command": "/opt/homebrew/bin/swiftlint ${file}",
      "problemMatcher": [],
      "presentation": {
        "echo": false,
        "showReuseMessage": false
      }
    },
    {
      "label": "Format and lint current file",
      "problemMatcher": [],
      "dependsOn": [
